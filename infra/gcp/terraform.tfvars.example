project_id             = "gcp-project-id"
region                 = "europe-west1"
environment            = "prod"
ops_image              = "europe-west1-docker.pkg.dev/PROJECT/ortaklar-ops/backup-restore:COMMIT"
artifact_repository_id = "ortaklar-ops"
supabase_project_ref   = "supabase-project-ref"
restore_supabase_project_ref = "isolated-restore-project-ref"
daily_bucket_name      = "ortaklar-prod-backup-daily"
monthly_bucket_name    = "ortaklar-prod-backup-monthly"
audit_bucket_name      = "ortaklar-prod-audit-archive"
monitoring_email       = "operasyon@example.com"
report_error_url       = "https://PROJECT.supabase.co/functions/v1/report-error"

secret_ids = {
  prod_db_url                = "ortaklar-prod-db-url"
  supabase_access_token     = "ortaklar-supabase-access-token"
  restore_db_url            = "ortaklar-restore-db-url"
  restore_supabase_url      = "ortaklar-restore-supabase-url"
  restore_supabase_anon_key = "ortaklar-restore-anon-key"
  auth_canary_email         = "ortaklar-auth-canary-email"
  auth_canary_password      = "ortaklar-auth-canary-password"
  auth_canary_uuid          = "ortaklar-auth-canary-uuid"
  ops_alert_secret          = "ortaklar-ops-alert-secret"
}
